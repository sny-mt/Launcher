                                                </Border>
                                                <TextBlock x:Name="check" Text="✓" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,2,0" Visibility="Collapsed">
                                                    <TextBlock.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black"/></TextBlock.Effect>
                                                </TextBlock>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#222"/>
