                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#222"/>
                                                    <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <RadioButton GroupName="ThemeColor" IsChecked="{Binding ThemeColor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Mint}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Grid>
                                                <Border x:Name="border" Width="50" Height="28" CornerRadius="4" Background="#00B1A9" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                                                    <TextBlock Text="Mint" Foreground="White" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock x:Name="check" Text="✓" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,2,0" Visibility="Collapsed">
                                                    <TextBlock.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black"/></TextBlock.Effect>
                                                </TextBlock>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#222"/>
                                                    <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <RadioButton GroupName="ThemeColor" IsChecked="{Binding ThemeColor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Sunset}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Grid>
                                                <Border x:Name="border" Width="50" Height="28" CornerRadius="4" Background="#FF6347" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                                                    <TextBlock Text="Sunset" Foreground="White" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock x:Name="check" Text="✓" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,2,0" Visibility="Collapsed">
                                                    <TextBlock.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black"/></TextBlock.Effect>
                                                </TextBlock>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#222"/>
                                                    <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </WrapPanel>

                            <TextBlock Text="透明度"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="不透明" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="0.7" Value="{Binding WindowOpacity}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="透明" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Center" Margin="8,0,8,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding WindowOpacity, StringFormat={}{0:P0}}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- 表示設定 -->
                        <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=表示}">
                            <TextBlock Text="表示モード"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <RadioButton Content="タイル" Foreground="{DynamicResource TextBrush}" IsChecked="{Binding ViewMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Tile}" Margin="0,0,16,0"/>
                                <RadioButton Content="リスト" Foreground="{DynamicResource TextBrush}" IsChecked="{Binding ViewMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=List}"/>
                            </StackPanel>

                            <TextBlock Text="タイルサイズ"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <RadioButton Content="小" Foreground="{DynamicResource TextBrush}" IsChecked="{Binding TileSize, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Small}" Margin="0,0,16,0"/>
                                <RadioButton Content="中" Foreground="{DynamicResource TextBrush}" IsChecked="{Binding TileSize, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Medium}" Margin="0,0,16,0"/>
                                <RadioButton Content="大" Foreground="{DynamicResource TextBrush}" IsChecked="{Binding TileSize, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Large}"/>
                            </StackPanel>

                            <TextBlock Text="カテゴリ表示方式"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <ComboBox SelectedValue="{Binding CategoryDisplayMode}" SelectedValuePath="Tag" Width="200" HorizontalAlignment="Left">
                                <ComboBoxItem Content="タブ（上部）" Tag="{x:Static enums:CategoryDisplayMode.TabTop}"/>
                                <ComboBoxItem Content="タブ（左部）" Tag="{x:Static enums:CategoryDisplayMode.TabLeft}"/>
                                <ComboBoxItem Content="サイドバー" Tag="{x:Static enums:CategoryDisplayMode.Sidebar}"/>
                                <ComboBoxItem Content="ドロップダウン" Tag="{x:Static enums:CategoryDisplayMode.Dropdown}"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- ホットキー設定 -->
                        <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=ホットキー}">
                            <TextBlock Text="ランチャー表示/非表示"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="設定したキーの組み合わせでランチャーを表示/非表示できます。"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="{DynamicResource TertiaryBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,10">
                                    <TextBlock Text="{Binding HotkeyDisplayText}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <Button Grid.Column="1"
                                        Content="変更"
                                        Command="{Binding StartRecordHotkeyCommand}"
                                        Margin="12,0,0,0"
                                        Padding="20,10"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="White"
                                        BorderThickness="0"/>
                            </Grid>
                        </StackPanel>

                        <!-- 動作設定 -->
                        <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=動作}">
                            <TextBlock Text="起動"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <CheckBox Content="Windows起動時に自動起動"
                                      Foreground="{DynamicResource TextBrush}"
                                      IsChecked="{Binding StartWithWindows}"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="起動時に最小化（トレイに格納）"
                                      Foreground="{DynamicResource TextBrush}"
                                      IsChecked="{Binding StartMinimized}"
                                      Margin="0,0,0,20"/>

                            <TextBlock Text="アイテム起動後"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <CheckBox Content="アイテム起動後にウィンドウを隠す"
                                      Foreground="{DynamicResource TextBrush}"
                                      IsChecked="{Binding HideAfterLaunch}"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ボタン -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="16">
                <Button Content="キャンセル"
                        Click="CancelButton_Click"
                        Padding="24,8"
                        Margin="0,0,8,0"
                        Background="{DynamicResource TertiaryBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderThickness="0"/>
                <Button Content="保存"
                        Click="SaveButton_Click"
                        Padding="24,8"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
