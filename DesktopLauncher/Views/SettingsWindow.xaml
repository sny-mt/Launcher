                            </WrapPanel>

                            <TextBlock Text="透明度"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="不透明" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="0.7" Value="{Binding WindowOpacity}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="透明" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Center" Margin="8,0,8,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding WindowOpacity, StringFormat={}{0:P0}}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- 表示設定 -->
                        <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=表示}">
                            <TextBlock Text="タイルサイズ"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <RadioButton Content="小" Foreground="{DynamicResource TextBrush}" IsChecked="{Binding TileSize, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Small}" Margin="0,0,16,0"/>
                                <RadioButton Content="中" Foreground="{DynamicResource TextBrush}" IsChecked="{Binding TileSize, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Medium}" Margin="0,0,16,0"/>
                                <RadioButton Content="大" Foreground="{DynamicResource TextBrush}" IsChecked="{Binding TileSize, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Large}"/>
                            </StackPanel>

                            <TextBlock Text="アイコンサイズ"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="24" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider Grid.Column="1" Minimum="24" Maximum="64" Value="{Binding IconSize}" TickFrequency="4" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding IconSize, StringFormat={}{0:0}px}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <TextBlock Text="フォントサイズ"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="8" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider Grid.Column="1" Minimum="8" Maximum="16" Value="{Binding FontSize}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding FontSize, StringFormat={}{0:0}pt}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <TextBlock Text="フォント"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <ComboBox SelectedValue="{Binding FontFamily}"
                                      SelectedValuePath="Tag"
                                      Width="200"
                                      HorizontalAlignment="Left"
                                      Margin="0,0,0,20">
                                <ComboBoxItem Tag="Yu Gothic UI">
                                    <TextBlock Text="Yu Gothic UI" FontFamily="Yu Gothic UI"/>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Meiryo UI">
                                    <TextBlock Text="Meiryo UI" FontFamily="Meiryo UI"/>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Meiryo">
                                    <TextBlock Text="Meiryo" FontFamily="Meiryo"/>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="MS UI Gothic">
                                    <TextBlock Text="MS UI Gothic" FontFamily="MS UI Gothic"/>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="BIZ UDGothic">
                                    <TextBlock Text="BIZ UDGothic" FontFamily="BIZ UDGothic"/>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Segoe UI">
                                    <TextBlock Text="Segoe UI" FontFamily="Segoe UI"/>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Arial">
                                    <TextBlock Text="Arial" FontFamily="Arial"/>
                                </ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <!-- ホットキー設定 -->
                        <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=ホットキー}">
                            <TextBlock Text="ランチャー表示/非表示"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="設定したキーの組み合わせでランチャーを表示/非表示できます。"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="{DynamicResource TertiaryBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,10">
                                    <TextBlock Text="{Binding HotkeyDisplayText}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <Button Grid.Column="1"
                                        Content="変更"
                                        Command="{Binding StartRecordHotkeyCommand}"
                                        Margin="12,0,0,0"
                                        Padding="20,10"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="White"
                                        BorderThickness="0"/>
                            </Grid>
                        </StackPanel>

                        <!-- 動作設定 -->
                        <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=動作}">
                            <TextBlock Text="起動"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <CheckBox Content="Windows起動時に自動起動"
                                      Foreground="{DynamicResource TextBrush}"
                                      IsChecked="{Binding StartWithWindows}"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="起動時に最小化（トレイに格納）"
                                      Foreground="{DynamicResource TextBrush}"
                                      IsChecked="{Binding StartMinimized}"
                                      Margin="0,0,0,20"/>

                            <TextBlock Text="アイテム起動後"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <CheckBox Content="アイテム起動後にウィンドウを隠す"
                                      Foreground="{DynamicResource TextBrush}"
                                      IsChecked="{Binding HideAfterLaunch}"/>
                        </StackPanel>

                        <!-- データ設定 -->
                        <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=データ}">
                            <TextBlock Text="データ管理"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="登録済みアイテムやカテゴリ、設定をファイルに書き出したり、読み込んだりできます。"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="エクスポート"
                                        Command="{Binding ExportDataCommand}"
                                        Padding="20,10"
                                        Margin="0,0,8,0"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="White"
                                        BorderThickness="0"/>
                                <Button Content="インポート"
                                        Command="{Binding ImportDataCommand}"
                                        Padding="20,10"
                                        Background="{DynamicResource TertiaryBrush}"
                                        Foreground="{DynamicResource TextBrush}"
                                        BorderThickness="0"/>
                            </StackPanel>

                            <TextBlock Text="{Binding ExportImportMessage}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ボタン -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="16">
                <Button Content="キャンセル"
                        Click="CancelButton_Click"
                        Padding="24,8"
                        Margin="0,0,8,0"
                        Background="{DynamicResource TertiaryBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderThickness="0"/>
                <Button Content="保存"
                        Click="SaveButton_Click"
                        Padding="24,8"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
