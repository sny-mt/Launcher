<Window x:Class="DesktopLauncher.Views.ItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="アイテム編集"
        Width="450" Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="{DynamicResource PrimaryBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトルバー -->
            <Grid Grid.Row="0" Background="{DynamicResource SecondaryBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding IsNewItem, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=新規追加}"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="16,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="編集"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewItem}" Value="True">
                                    <Setter Property="Text" Value="新規追加"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button Grid.Column="1"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click"
                        Margin="8">
                    <TextBlock Text="✕" FontSize="12"/>
                </Button>
            </Grid>

            <!-- 編集内容 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Margin="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- アイコンプレビュー -->
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
                        <Border Background="{DynamicResource TertiaryBrush}"
                                CornerRadius="8"
                                Padding="16">
                            <Image Source="{Binding PreviewIcon}"
                                   Width="64" Height="64"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                            <Button Content="アイコン変更"
                                    Command="{Binding BrowseIconCommand}"
                                    Padding="12,6"
                                    Margin="0,0,0,4"
                                    Background="{DynamicResource TertiaryBrush}"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderThickness="0"/>
                            <Button Content="リセット"
                                    Command="{Binding ClearIconCommand}"
                                    Padding="12,6"
                                    Background="{DynamicResource TertiaryBrush}"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 名前 -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="名前"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,12"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             Margin="0,0,0,12"/>

                    <!-- パス -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="パス"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,12"/>
                    <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"/>
                        <Button Grid.Column="1"
                                Content="..."
                                Command="{Binding BrowsePathCommand}"
                                Padding="12,8"
                                Margin="4,0,0,0"
                                Background="{DynamicResource TertiaryBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0"
                                ToolTip="ファイルを選択"/>
                        <Button Grid.Column="2"
                                Content="📁"
                                Command="{Binding BrowseFolderCommand}"
                                Padding="12,8"
                                Margin="4,0,0,0"
                                Background="{DynamicResource TertiaryBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0"
                                ToolTip="フォルダを選択"/>
                    </Grid>

                    <!-- 引数 -->
                    <TextBlock Grid.Row="3" Grid.Column="0"
                               Text="引数"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,12"/>
                    <TextBox Grid.Row="3" Grid.Column="1"
                             Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             Margin="0,0,0,12"/>

                    <!-- 作業ディレクトリ -->
                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="作業フォルダ"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,12"/>
                    <Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBoxStyle}"/>
                        <Button Grid.Column="1"
                                Content="..."
                                Command="{Binding BrowseWorkingDirectoryCommand}"
                                Padding="12,8"
                                Margin="4,0,0,0"
                                Background="{DynamicResource TertiaryBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0"/>
                    </Grid>

                </Grid>
            </ScrollViewer>

            <!-- ボタン -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="16">
                <Button Content="キャンセル"
                        Click="CancelButton_Click"
                        Padding="24,8"
                        Margin="0,0,8,0"
                        Background="{DynamicResource TertiaryBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderThickness="0"/>
                <Button Content="保存"
                        Click="SaveButton_Click"
                        Padding="24,8"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
