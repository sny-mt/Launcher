<Window x:Class="DesktopLauncher.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:enums="clr-namespace:DesktopLauncher.Models.Enums"
        mc:Ignorable="d"
        Title="設定"
        Width="700" Height="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="{DynamicResource DialogPrimaryBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトルバー -->
            <Grid Grid.Row="0" Background="{DynamicResource SecondaryBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="設定"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="16,12"/>

                <Button Grid.Column="1"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click"
                        Margin="8">
                    <TextBlock Text="✕" FontSize="12"/>
                </Button>
            </Grid>

            <!-- メインコンテンツ（左：メニュー、右：詳細） -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左側メニュー -->
                <ListBox Grid.Column="0"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8"
                         SelectedValue="{Binding SelectedSettingsCategory}"
                         SelectedValuePath="Content">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="外観"/>
                    <ListBoxItem Content="表示"/>
                    <ListBoxItem Content="ホットキー"/>
                    <ListBoxItem Content="動作"/>
                </ListBox>

                <!-- 区切り線 -->
                <Border Grid.Column="1" Background="{DynamicResource BorderBrush}"/>

                <!-- 右側詳細 -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              Margin="16">

                    <Grid>
                        <!-- 外観設定 -->
                        <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=外観}">
                            <TextBlock Text="テーマ"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <WrapPanel Margin="0,0,0,20">
                                <!-- Dark -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Dark}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#1E1E1E" Cursor="Hand" BorderThickness="2" BorderBrush="Transparent">
                                                <TextBlock Text="Dark" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Light -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Light}" Margin="0,0,6,6">
                                    <RadioButton.Template>
