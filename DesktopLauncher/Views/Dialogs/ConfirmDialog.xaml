<Window x:Class="DesktopLauncher.Views.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="確認"
        Width="380" Height="180"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="{DynamicResource DialogPrimaryBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトルバー -->
            <Grid Grid.Row="0" Background="{DynamicResource DialogSecondaryBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TitleText"
                           Text="確認"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="16,12"/>

                <Button Grid.Column="1"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click"
                        Margin="8">
                    <TextBlock Text="✕" FontSize="12"/>
                </Button>
            </Grid>

            <!-- メッセージ -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="?"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <TextBlock x:Name="MessageText"
                           Grid.Column="1"
                           Text="確認メッセージ"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- ボタン -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="16">
                <Button Content="いいえ"
                        Click="NoButton_Click"
                        Padding="24,8"
                        Margin="0,0,8,0"
                        Background="{DynamicResource TertiaryBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderThickness="0"/>
                <Button x:Name="YesButton"
                        Content="はい"
                        Click="YesButton_Click"
                        Padding="24,8"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
