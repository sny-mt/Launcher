<Window x:Class="DesktopLauncher.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="入力"
        Width="400" Height="220"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="{DynamicResource DialogPrimaryBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトルバー -->
            <Grid Grid.Row="0" Background="{DynamicResource SecondaryBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TitleText"
                           Text="入力"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="16,12"/>

                <Button Grid.Column="1"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click"
                        Margin="8">
                    <TextBlock Text="✕" FontSize="12"/>
                </Button>
            </Grid>

            <!-- 入力内容 -->
            <StackPanel Grid.Row="1" Margin="16">
                <TextBlock x:Name="PromptText"
                           Text="URLを入力してください"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="InputTextBox"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Text=""
                         KeyDown="InputTextBox_KeyDown"/>
            </StackPanel>

            <!-- ボタン -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="16">
                <Button Content="キャンセル"
                        Click="CancelButton_Click"
                        Padding="24,8"
                        Margin="0,0,8,0"
                        Background="{DynamicResource TertiaryBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderThickness="0"/>
                <Button Content="OK"
                        Click="OkButton_Click"
                        Padding="24,8"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
