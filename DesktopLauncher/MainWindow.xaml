<Window x:Class="DesktopLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DesktopLauncher.ViewModels"
        xmlns:controls="clr-namespace:DesktopLauncher.Infrastructure.Controls"
        mc:Ignorable="d"
        Title="Desktop Launcher"
        Width="770" Height="600"
        MinWidth="770" MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Topmost="True"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="{DynamicResource PrimaryBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="10"
            PreviewMouseLeftButtonDown="Border_PreviewMouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ヘッダー（検索バー・設定ボタン・ウィンドウコントロール） -->
            <Grid Grid.Row="0" Margin="16,12,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 検索ボックス -->
                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0"/>

                <!-- 設定ボタン -->
                <Button Grid.Column="1"
                        Style="{StaticResource IconButtonStyle}"
                        Command="{Binding ShowSettingsCommand}"
                        ToolTip="設定">
                    <TextBlock Text="⚙" FontSize="16"/>
                </Button>

                <!-- 前面固定ボタン -->
                <Button x:Name="TopmostButton"
                        Grid.Column="2"
                        Style="{StaticResource IconButtonStyle}"
                        Click="TopmostButton_Click"
                        ToolTip="前面固定"
                        Margin="4,0,0,0">
                    <TextBlock Text="📌" FontSize="14"/>
                </Button>

                <!-- 最小化ボタン -->
                <Button Grid.Column="3"
                        Style="{StaticResource IconButtonStyle}"
                        Click="MinimizeButton_Click"
                        ToolTip="最小化"
                        Margin="4,0,0,0">
                    <TextBlock Text="─" FontSize="14"/>
                </Button>

                <!-- 閉じるボタン -->
                <Button Grid.Column="4"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click"
                        ToolTip="閉じる"
                        Margin="4,0,0,0">
                    <TextBlock Text="✕" FontSize="14"/>
                </Button>
            </Grid>

            <!-- カテゴリタブ -->
            <ScrollViewer Grid.Row="1" Margin="16,0,16,8"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="CategoryScrollViewer_PreviewMouseWheel">
                <StackPanel Orientation="Horizontal">
                    <TabControl Style="{StaticResource CategoryTabControlStyle}"
                                ItemsSource="{Binding Categories}"
                                SelectedItem="{Binding SelectedCategory}"
                                Tag="{Binding}">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource AccentBrush}"
                                            CornerRadius="8"
                                            Padding="6,2"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding SearchMatchCount}"
                                                   Foreground="White"
                                                   FontSize="10"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ItemContainerStyle>
                            <Style TargetType="TabItem" BasedOn="{StaticResource CategoryTabItemStyle}">
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TabControl}}"/>
                                <Setter Property="AllowDrop" Value="True"/>
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TabItem_PreviewMouseLeftButtonDown"/>
                                <EventSetter Event="PreviewMouseMove" Handler="TabItem_PreviewMouseMove"/>
                                <EventSetter Event="MouseDoubleClick" Handler="TabItem_MouseDoubleClick"/>
                                <EventSetter Event="Drop" Handler="TabItem_Drop"/>
                                <EventSetter Event="DragOver" Handler="TabItem_DragOver"/>
                                <EventSetter Event="DragLeave" Handler="TabItem_DragLeave"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="カテゴリ名を編集"
                                                      Command="{Binding PlacementTarget.Tag.EditCategoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="削除"
                                                      Command="{Binding PlacementTarget.Tag.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.ItemContainerStyle>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <!-- 空のテンプレート（コンテンツは別で表示） -->
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <!-- カテゴリ追加ボタン（タブの隣に配置） -->
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding AddCategoryCommand}"
                            ToolTip="カテゴリを追加"
                            VerticalAlignment="Center"
                            Margin="4,0,0,0">
                        <TextBlock Text="＋" FontSize="14" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <!-- アイテムグリッド -->
            <Grid Grid.Row="2" Margin="16,0,16,16" Background="Transparent"
                  Tag="{Binding}">
                <Grid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="追加" Command="{Binding AddItemCommand}"/>
                        <MenuItem Header="URL追加" Command="{Binding AddUrlCommand}"/>
                        <Separator/>
                        <MenuItem Header="整列" Command="{Binding ArrangeItemsCommand}"/>
                    </ContextMenu>
                </Grid.ContextMenu>

                <!-- グリッドスロット表示（検索していない時） -->
                <ItemsControl x:Name="GridSlotsControl"
                              ItemsSource="{Binding GridSlots}"
                              Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Invert}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding DataContext.GridColumns, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Rows="{Binding DataContext.GridRows, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource TertiaryBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="2"
                                    AllowDrop="True"
                                    Drop="GridSlot_Drop"
                                    DragOver="GridSlot_DragOver"
                                    DragLeave="GridSlot_DragLeave"
                                    Tag="{Binding SlotIndex}">
                                <!-- アイテムがある場合 -->
                                <Button Style="{StaticResource TileButtonStyle}"
                                        Visibility="{Binding HasItem, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Command="{Binding DataContext.LaunchItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Item}"
                                        PreviewMouseLeftButtonDown="TileButton_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="TileButton_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="TileButton_PreviewMouseLeftButtonUp"
                                        ToolTipService.InitialShowDelay="500"
                                        ToolTipService.ShowDuration="10000">
                                    <Button.ToolTip>
                                        <ToolTip>
                                            <ToolTip.Style>
                                                <Style TargetType="ToolTip">
                                                    <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="Padding" Value="8,6"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                </Style>
                                            </ToolTip.Style>
                                            <TextBlock Text="{Binding Item.Path}" TextWrapping="Wrap" MaxWidth="300"/>
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="開く"
                                                      Command="{Binding PlacementTarget.Tag.LaunchItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext.Item, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="管理者として実行"
                                                      Command="{Binding PlacementTarget.Tag.LaunchItemAsAdminCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext.Item, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="ファイルの場所を開く"
                                                      Command="{Binding PlacementTarget.Tag.OpenFileLocationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext.Item, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="編集"
                                                      Command="{Binding PlacementTarget.Tag.EditItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext.Item, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="削除"
                                                      Command="{Binding PlacementTarget.Tag.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext.Item, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                        <Image Source="{Binding Item.Icon}"
                                               Width="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}, ConverterParameter=Icon}"
                                               Height="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}, ConverterParameter=Icon}"
                                               HorizontalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding Item.Name}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}, ConverterParameter=Font}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}, ConverterParameter=TextHeight}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 検索結果表示（検索している時） -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding DisplayedItems}"
                                  Background="Transparent">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource TileButtonStyle}"
                                        Width="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}}"
                                        Height="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}}"
                                        Margin="4"
                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Command="{Binding DataContext.LaunchItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        ToolTipService.InitialShowDelay="500">
                                    <Button.ToolTip>
                                        <TextBlock Text="{Binding Path}" TextWrapping="Wrap" MaxWidth="300"/>
                                    </Button.ToolTip>
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="開く"
                                                      Command="{Binding PlacementTarget.Tag.LaunchItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="編集"
                                                      Command="{Binding PlacementTarget.Tag.EditItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                        <Image Source="{Binding Icon}"
                                               Width="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}, ConverterParameter=Icon}"
                                               Height="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}, ConverterParameter=Icon}"
                                               HorizontalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <controls:HighlightTextBlock
                                                   SourceText="{Binding Name}"
                                                   HighlightText="{Binding DataContext.SearchText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   HighlightBrush="{DynamicResource AccentBrush}"
                                                   HighlightForeground="White"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}, ConverterParameter=Font}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}, ConverterParameter=Text}"
                                                   MaxHeight="{Binding DataContext.Settings.TileSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TileSizeToDoubleConverter}, ConverterParameter=TextHeight}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- トースト通知 -->
            <ItemsControl Grid.Row="2"
                          ItemsSource="{Binding Toasts}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,16,16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource DialogSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,10"
                                Margin="0,4,0,0"
                                MinWidth="200"
                                MaxWidth="300">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsClosing}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0" Duration="0:0:0.3"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding IconText}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Success">
                                                    <Setter Property="Foreground" Value="#FF4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Error">
                                                    <Setter Property="Foreground" Value="#FFE85959"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Warning">
                                                    <Setter Property="Foreground" Value="#FFFFC107"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Message}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>
    </Border>
</Window>
