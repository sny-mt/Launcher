<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ダークテーマカラー（半透明） -->
    <Color x:Key="PrimaryColor">#E01E1E1E</Color>
    <Color x:Key="SecondaryColor">#D0252526</Color>
    <Color x:Key="TertiaryColor">#C02D2D30</Color>

    <!-- ダイアログ用（不透明） -->
    <Color x:Key="DialogPrimaryColor">#FF1E1E1E</Color>
    <Color x:Key="DialogSecondaryColor">#FF252526</Color>
    <Color x:Key="AccentColor">#FF007ACC</Color>
    <Color x:Key="AccentHoverColor">#FF1C97EA</Color>
    <Color x:Key="TextColor">#FFFFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#CCCCCCCC</Color>
    <Color x:Key="BorderColor">#803F3F46</Color>
    <Color x:Key="HoverColor">#603E3E42</Color>
    <Color x:Key="SelectedColor">#80094771</Color>

    <!-- ブラシ -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource TertiaryColor}"/>

    <!-- ダイアログ用ブラシ（不透明） -->
    <SolidColorBrush x:Key="DialogPrimaryBrush" Color="{StaticResource DialogPrimaryColor}"/>
    <SolidColorBrush x:Key="DialogSecondaryBrush" Color="{StaticResource DialogSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}"/>

</ResourceDictionary>
