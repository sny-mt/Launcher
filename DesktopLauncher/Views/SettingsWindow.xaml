<Window x:Class="DesktopLauncher.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="設定"
        Width="700" Height="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="{DynamicResource DialogPrimaryBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトルバー -->
            <Grid Grid.Row="0" Background="{DynamicResource SecondaryBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="設定"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="16,12"/>

                <Button Grid.Column="1"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click"
                        Margin="8">
                    <TextBlock Text="✕" FontSize="12"/>
                </Button>
            </Grid>

            <!-- メインコンテンツ（左：メニュー、右：詳細） -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左側メニュー -->
                <ListBox Grid.Column="0"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8"
                         SelectedValue="{Binding SelectedSettingsCategory}"
                         SelectedValuePath="Content">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="外観"/>
                    <ListBoxItem Content="表示"/>
                    <ListBoxItem Content="ホットキー"/>
                    <ListBoxItem Content="動作"/>
                    <ListBoxItem Content="データ"/>
                </ListBox>

                <!-- 区切り線 -->
                <Border Grid.Column="1" Background="{DynamicResource BorderBrush}"/>

                <!-- 右側詳細 -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              Margin="16">

                    <Grid>
                        <!-- 外観設定 -->
                        <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=外観}">
                            <TextBlock Text="テーマ"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <WrapPanel Margin="0,0,0,20">
                                <!-- Dark -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Dark}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#1E1E1E" Cursor="Hand" BorderThickness="2" BorderBrush="Transparent">
                                                <TextBlock Text="Dark" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Light -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Light}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#F5F5F5" Cursor="Hand" BorderThickness="2" BorderBrush="#CCC">
                                                <TextBlock Text="Light" Foreground="#333" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Midnight -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Midnight}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#0F172A" Cursor="Hand" BorderThickness="2" BorderBrush="Transparent">
                                                <TextBlock Text="Midnight" Foreground="#E2E8F0" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Sepia -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Sepia}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#44372B" Cursor="Hand" BorderThickness="2" BorderBrush="Transparent">
                                                <TextBlock Text="Sepia" Foreground="#FFF8EB" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Forest -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Forest}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#142D23" Cursor="Hand" BorderThickness="2" BorderBrush="Transparent">
                                                <TextBlock Text="Forest" Foreground="#DCF0E6" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Ocean -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Ocean}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#0F2D4B" Cursor="Hand" BorderThickness="2" BorderBrush="Transparent">
                                                <TextBlock Text="Ocean" Foreground="#E0F0FF" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Rose -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Rose}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#412332" Cursor="Hand" BorderThickness="2" BorderBrush="Transparent">
                                                <TextBlock Text="Rose" Foreground="#FFEBF0" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Slate -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Slate}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#2D3237" Cursor="Hand" BorderThickness="2" BorderBrush="Transparent">
                                                <TextBlock Text="Slate" Foreground="#EBEEF2" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Sakura -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Sakura}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#FFF0F5" Cursor="Hand" BorderThickness="2" BorderBrush="#FFB6C1">
                                                <TextBlock Text="Sakura" Foreground="#DB7093" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#FF69B4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Lavender -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Lavender}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#F5F0FF" Cursor="Hand" BorderThickness="2" BorderBrush="#D8BFD8">
                                                <TextBlock Text="Lavender" Foreground="#8B7B8B" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#9370DB"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Candy -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Candy}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#FFF5FA" Cursor="Hand" BorderThickness="2" BorderBrush="#FFB6C1">
                                                <TextBlock Text="Candy" Foreground="#FF69B4" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#FF1493"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Peach -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Peach}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#FFF5EE" Cursor="Hand" BorderThickness="2" BorderBrush="#FFDAB9">
                                                <TextBlock Text="Peach" Foreground="#CD853F" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#FF8C69"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Milky -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Milky}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#FFFEFA" Cursor="Hand" BorderThickness="2" BorderBrush="#F5DEB3">
                                                <TextBlock Text="Milky" Foreground="#A0926E" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#DEB887"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Dreamy -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Dreamy}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Background="#F0EBFF" Cursor="Hand" BorderThickness="2" BorderBrush="#E6E0FF">
                                                <TextBlock Text="Dreamy" Foreground="#9370DB" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#BA55D3"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <!-- Custom -->
                                <RadioButton GroupName="Theme" IsChecked="{Binding Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Custom}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Width="58" Height="32" CornerRadius="4" Cursor="Hand" BorderThickness="2" BorderBrush="{DynamicResource BorderBrush}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FF6B6B" Offset="0"/>
                                                        <GradientStop Color="#4ECDC4" Offset="0.5"/>
                                                        <GradientStop Color="#45B7D1" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="Custom" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black" Opacity="0.5"/></TextBlock.Effect>
                                                </TextBlock>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </WrapPanel>

                            <!-- カスタムカラー設定 -->
                            <StackPanel Visibility="{Binding IsCustomTheme, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,0,0,20">
                                <TextBlock Text="カスタムカラー"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12"/>

                                <TextBlock Text="色を変更するとリアルタイムでプレビューされます。"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,0,0,12"/>

                                <!-- ベースカラー -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="背景色" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0" Cursor="Hand"
                                            MouseLeftButtonDown="PickBaseColor_Click">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding CustomBaseColor}"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Grid.Column="2" Text="{Binding CustomBaseColor, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchTextBoxStyle}" MaxLength="7" Width="80" Margin="0,0,4,0"/>
                                    <Button Grid.Column="3" Content="🎨" Click="PickBaseColor_Click" ToolTip="カラーパレット"
                                            Style="{StaticResource IconButtonStyle}" Width="28" Height="28" FontSize="14" Margin="0,0,2,0"/>
                                    <Button Grid.Column="4" Content="💧" Click="EyedropBaseColor_Click" ToolTip="スポイト（画面の色を取得）"
                                            Style="{StaticResource IconButtonStyle}" Width="28" Height="28" FontSize="14"/>
                                </Grid>

                                <!-- テキストカラー -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="文字色" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0" Cursor="Hand"
                                            MouseLeftButtonDown="PickTextColor_Click">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding CustomTextColor}"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Grid.Column="2" Text="{Binding CustomTextColor, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchTextBoxStyle}" MaxLength="7" Width="80" Margin="0,0,4,0"/>
                                    <Button Grid.Column="3" Content="🎨" Click="PickTextColor_Click" ToolTip="カラーパレット"
                                            Style="{StaticResource IconButtonStyle}" Width="28" Height="28" FontSize="14" Margin="0,0,2,0"/>
                                    <Button Grid.Column="4" Content="💧" Click="EyedropTextColor_Click" ToolTip="スポイト（画面の色を取得）"
                                            Style="{StaticResource IconButtonStyle}" Width="28" Height="28" FontSize="14"/>
                                </Grid>

                                <!-- アクセントカラー -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="アクセント色" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0" Cursor="Hand"
                                            MouseLeftButtonDown="PickAccentColor_Click">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding CustomAccentColor}"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Grid.Column="2" Text="{Binding CustomAccentColor, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchTextBoxStyle}" MaxLength="7" Width="80" Margin="0,0,4,0"/>
                                    <Button Grid.Column="3" Content="🎨" Click="PickAccentColor_Click" ToolTip="カラーパレット"
                                            Style="{StaticResource IconButtonStyle}" Width="28" Height="28" FontSize="14" Margin="0,0,2,0"/>
                                    <Button Grid.Column="4" Content="💧" Click="EyedropAccentColor_Click" ToolTip="スポイト（画面の色を取得）"
                                            Style="{StaticResource IconButtonStyle}" Width="28" Height="28" FontSize="14"/>
                                </Grid>
                            </StackPanel>

                            <TextBlock Text="テーマカラー"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCustomTheme}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <WrapPanel Margin="0,0,0,20">
                                <WrapPanel.Style>
                                    <Style TargetType="WrapPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCustomTheme}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </WrapPanel.Style>
                                <RadioButton GroupName="ThemeColor" IsChecked="{Binding ThemeColor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Blue}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Grid>
                                                <Border x:Name="border" Width="50" Height="28" CornerRadius="4" Background="#0078D4" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                                                    <TextBlock Text="Blue" Foreground="White" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock x:Name="check" Text="✓" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,2,0" Visibility="Collapsed">
                                                    <TextBlock.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black"/></TextBlock.Effect>
                                                </TextBlock>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#222"/>
                                                    <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <RadioButton GroupName="ThemeColor" IsChecked="{Binding ThemeColor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Pink}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Grid>
                                                <Border x:Name="border" Width="50" Height="28" CornerRadius="4" Background="#E3008C" Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                                                    <TextBlock Text="Pink" Foreground="White" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock x:Name="check" Text="✓" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,2,0" Visibility="Collapsed">
                                                    <TextBlock.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black"/></TextBlock.Effect>
                                                </TextBlock>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#222"/>
                                                    <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                                <RadioButton GroupName="ThemeColor" IsChecked="{Binding ThemeColor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Green}" Margin="0,0,6,6">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Grid>
